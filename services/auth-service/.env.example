NODE_ENV=development
PORT=3001

# PostgreSQL — chỉ schema auth
DATABASE_URL=postgresql://novapay:novapay_secret@localhost:5432/novapay?schema=auth

# Redis
REDIS_URL=redis://:redis_secret@localhost:6379

# JWT
JWT_SECRET=your_jwt_secret_min_32_chars_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Internal secret — verify calls từ services khác
INTERNAL_SECRET=your_internal_secret_here
